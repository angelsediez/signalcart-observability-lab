# SignalCart Observability Lab
# Copy this file to .env for local use.
# Do not commit real secrets.

PROJECT_NAME="SignalCart Observability Lab"
APP_NAME="SignalCart API"
APP_ENV=local
APP_VERSION=0.1.0

# FastAPI runtime
APP_HOST=0.0.0.0
APP_PORT=8000

# PostgreSQL
POSTGRES_DB=signalcart
POSTGRES_USER=signalcart
POSTGRES_PASSWORD=signalcart-local-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://signalcart:signalcart-local-password@localhost:5432/signalcart

# Lab simulation controls
# Simulation endpoints are disabled unless SIMULATION_MODE=true.
SIMULATION_MODE=false
SIMULATION_TOKEN=change-me-for-local-lab-only

# Observability ports
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
ALERTMANAGER_PORT=9093
NGINX_PORT=8080

# Grafana local admin credentials for lab use only
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
