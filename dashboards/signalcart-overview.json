{
  "uid": "signalcart-overview",
  "title": "SignalCart Overview",
  "tags": [
    "signalcart",
    "overview"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
